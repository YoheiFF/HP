# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here

# デフォルトモデル（エージェント種別ごとに config/agents.yaml で上書き可能）
DEFAULT_MODEL=claude-sonnet-4-6

# メモリバックエンド: json | sqlite
MEMORY_BACKEND=json
MEMORY_DIR=./data/memory

# ログレベル: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 外部サービス連携（使用する場合のみ）
SLACK_BOT_TOKEN=
GITHUB_TOKEN=
NOTION_TOKEN=

# Web検索（使用する場合のみ）
BRAVE_SEARCH_API_KEY=
